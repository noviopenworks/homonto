/.homonto/
.env
# Release build output from scripts/build-release.sh.
/dist/
# Locally-built binaries (e.g. `go build ./cmd/onto`, `go build .`).
/onto
/homonto
graphify-out/
__pycache__/
# Per-developer tool state (machine-specific). The repo does not dogfood
# homonto, so nothing here is projected — these hold each developer's own
# Claude Code / OpenCode setup.
/.claude/
/.opencode/

# E2E matrix run logs (scratch)
test/e2e/.out/
/.superpowers/
# Comet per-change runtime artifacts (trajectory, checkpoints, skill snapshots).
# The tracked state file .comet.yaml and the durable artifacts stay tracked.
openspec/changes/*/.comet/
